{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WormFinding",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "kind",
    "schemaVersion",
    "findingId",
    "findingClass",
    "sourceRepo",
    "sourceArtifact",
    "relatedEdgeIds",
    "target",
    "reasonCode",
    "crawlScope",
    "confidence",
    "posture",
    "timestamp"
  ],
  "properties": {
    "kind": {
      "const": "worm_finding"
    },
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "findingId": {
      "type": "string",
      "minLength": 1
    },
    "findingClass": {
      "type": "string",
      "enum": [
        "stale_submodule_pointer",
        "missing_referenced_repo",
        "broken_workspace_member_reference",
        "missing_shared_contract_path",
        "repo_link_drift",
        "ci_points_to_missing_artifact",
        "declared_relationship_target_absent",
        "ambiguous_target_identity"
      ]
    },
    "sourceRepo": {
      "type": "string",
      "minLength": 1
    },
    "sourceArtifact": {
      "type": "object",
      "required": [
        "path"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "line": {
          "type": "integer",
          "minimum": 1
        },
        "artifactSha256": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "relatedEdgeIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "target": {
      "type": "object",
      "required": [
        "rawReference"
      ],
      "properties": {
        "rawReference": {
          "type": "string",
          "minLength": 1
        },
        "normalizedRepo": {
          "type": "string"
        },
        "targetPath": {
          "type": "string"
        },
        "identityPosture": {
          "type": "string",
          "enum": [
            "resolved",
            "ambiguous",
            "unresolved"
          ]
        }
      }
    },
    "reasonCode": {
      "type": "string",
      "minLength": 1
    },
    "crawlScope": {
      "type": "string",
      "enum": [
        "local_repo",
        "cross_repo",
        "external_reference"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unassessable"
      ]
    },
    "posture": {
      "type": "string",
      "enum": [
        "evidence_bound",
        "ambiguous",
        "unresolved",
        "blocked"
      ]
    },
    "timestamp": {
      "type": "string",
      "minLength": 1
    },
    "notes": {
      "type": "string"
    }
  }
}